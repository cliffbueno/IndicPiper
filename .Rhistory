# Libraries
library(vegan)
library(tidyverse)
# Data
data(dune)
data("dune.env")
# Make better rownames to more clearly match data and metadata
rownames(dune) <- c("sample1", "sample2", "sample3", "sample4", "sample5",
"sample6", "sample7", "sample8", "sample9", "sample10",
"sample11", "sample12", "sample13", "sample14", "sample15",
"sample16", "sample17", "sample18", "sample19", "sample20")
rownames(dune.env) <- c("sample1", "sample2", "sample3", "sample4", "sample5",
"sample6", "sample7", "sample8", "sample9", "sample10",
"sample11", "sample12", "sample13", "sample14", "sample15",
"sample16", "sample17", "sample18", "sample19", "sample20")
# Set up metadata for this example
dune.env <- dune.env %>%
mutate(Location = c(rep("Antarctica", 6),
rep("World", 14))) %>%
rownames_to_column(var = "sampleID") %>%
dplyr::select(sampleID, Location)
# Loop through 1000 times, record number shared each time
sim_results <- as.data.frame(matrix(NA, 1000, 2)) %>%
set_names(c("Simulation", "Num_shared"))
for (i in 1:1000) {
sim_results$Simulation[i] <- i
dune.env <- dune.env %>%
mutate(Location = sample(rep(c("Antarctica","World"), c(6,14))))
d <- dune %>%
rownames_to_column(var = "sampleID") %>%
left_join(., dune.env, by = "sampleID") %>%
column_to_rownames(var = "sampleID")
antar <- d %>%
filter(Location == "Antarctica") %>%
dplyr::select(-Location)
world <- d %>%
filter(Location == "World") %>%
dplyr::select(-Location)
a_results <- as.data.frame(colSums(antar)) %>%
set_names("Antarctica")
w_results <- as.data.frame(colSums(world)) %>%
set_names("World")
results <- cbind(a_results, w_results) %>%
mutate(Shared = ifelse(Antarctica > 0 & World > 0, 1, 0))
sim_results$Num_shared[i] <- sum(results$Shared)
}
View(antar)
View(a_results)
